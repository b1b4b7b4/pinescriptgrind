// Pine Script®
// © RakoQuant

//@version=6
indicator("KAMA SD Bands | RakoQuant", shorttitle="RQ KAMA SD", overlay=true, max_labels_count=500)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// INPUTS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
group_core = "Core"
group_kama = "KAMA"
group_sd   = "SD Bands"
group_sig  = "Signals"
group_viz  = "Visuals"

src = input.source(hlcc4, "Source", group=group_core)

// KAMA params
kamaLen  = input.int(7, "KAMA Length", minval=2, group=group_kama)
fastLen  = input.int(3,  "Fast Length", minval=2, group=group_kama)
slowLen  = input.int(42, "Slow Length", minval=3, group=group_kama)    

// SD bands
sdLen    = input.int(23, "StdDev Length (Residual)", minval=2, group=group_sd)
mult     = input.float(2.0, "StdDev Multiplier", minval=0.1, step=0.1, group=group_sd)

// Signals
sigMode  = input.string("Band Break", "Signal Mode",
     options=["Band Break", "Re-Entry (Mean)"],
     group=group_sig)

confirmClose = input.bool(true, "Confirm On Candle Close", group=group_sig)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// VISUAL OPTIONS 
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
palette = input.string("Ocean / Coral", "Palette",
     options=["RakoQuant Neon", "Classic", "Gold / Indigo", "Ocean / Coral", "Mono"],
     group=group_viz)

lineStyleOpt = input.string("Line", "Line Style",
     options=["Line", "Line Break", "Step"],
     group=group_viz)

showGlow    = input.bool(true, "Glow Effect", group=group_viz)
glowOuterW  = input.int(10, "Glow Outer Width", minval=1, maxval=20, group=group_viz)
glowInnerW  = input.int(6,  "Glow Inner Width", minval=1, maxval=20, group=group_viz)
mainWidth   = input.int(2,  "Main Width", minval=1, maxval=6, group=group_viz)

showFill    = input.bool(true, "Show Band Fill", group=group_viz)
fillOpacity = input.int(88, "Fill Opacity", minval=0, maxval=100, group=group_viz)

showBasis   = input.bool(true, "Show KAMA Baseline", group=group_viz)
basisOpacity= input.int(65, "Baseline Opacity", minval=0, maxval=100, group=group_viz)

paintBars   = input.bool(false, "Paint Candles", group=group_viz)
useTrendClr = input.bool(true, "Trend Colors (slope)", group=group_viz)

// Signal markers
showSignals = input.bool(true, "Show UP/DN Markers", group=group_viz)
markerStyle = input.string("Labels", "Marker Style", options=["Labels","Triangles","Off"], group=group_viz)
markerSize  = input.string("Normal", "Marker Size", options=["Small","Normal","Large"], group=group_viz)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// COLORS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bullCol =
     palette == "Classic"       ? color.lime :
     palette == "Gold / Indigo" ? color.rgb(255, 196, 0) :
     palette == "Ocean / Coral" ? color.rgb(0, 220, 255) :
     palette == "Mono"          ? color.rgb(230, 230, 230) :
                                  #00ffc3

bearCol =
     palette == "Classic"       ? color.red :
     palette == "Gold / Indigo" ? color.rgb(96, 86, 255) :
     palette == "Ocean / Coral" ? color.rgb(255, 105, 120) :
     palette == "Mono"          ? color.rgb(140, 140, 140) :
                                  #ff00d0

midCol = color.new(color.gray, 0)

plotStyle = lineStyleOpt == "Step"       ? plot.style_stepline :lineStyleOpt == "Line Break" ? plot.style_linebr :              plot.style_line

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// KAMA (manual, open-source)
// ER = |src - src[len]| / sum(|src - src[1]|, len)
// SC = (ER*(fastSC-slowSC)+slowSC)^2
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
f_kama(_src, _len, _fastLen, _slowLen) =>
    int L = math.max(_len, 2)
    int fL = math.max(_fastLen, 2)
    int sL = math.max(_slowLen, 2)

    float change = math.abs(_src - _src[L])

    // sum of absolute 1-bar changes over L (no ta.sum needed)
    float vol = 0.0
    for i = 0 to L - 1
        vol += math.abs(_src[i] - _src[i + 1])

    float er = vol != 0.0 ? change / vol : 0.0

    float fastSC = 2.0 / (fL + 1.0)
    float slowSC = 2.0 / (sL + 1.0)
    float sc = math.pow(er * (fastSC - slowSC) + slowSC, 2.0)

    var float k = na
    k := na(k[1]) ? _src : k[1] + sc * (_src - k[1])
    k

kama = f_kama(src, kamaLen, fastLen, slowLen)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SD BANDS (residual-based)
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
resid = src - kama
sd    = ta.stdev(resid, sdLen)

upper = kama + mult * sd
lower = kama - mult * sd

// trend coloring by slope
isUp     = kama >= kama[1]
trendCol = isUp ? bullCol : bearCol
bandCol  = useTrendClr ? trendCol : color.new(midCol, 0)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SIGNALS (stateful, backtest-friendly)
// RakoQuant =  1 bullish, -1 bearish
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bool bullTrig = sigMode == "Band Break" ? (close > upper) : ta.crossover(close, kama)
bool bearTrig = sigMode == "Band Break" ? (close < lower) : ta.crossunder(close, kama)

bool bullSignal = confirmClose ? (barstate.isconfirmed and bullTrig) : bullTrig
bool bearSignal = confirmClose ? (barstate.isconfirmed and bearTrig) : bearTrig

var int RakoQuant = 0
if bullSignal and not bearSignal
    RakoQuant := 1
if bearSignal
    RakoQuant := -1

bullFlip = RakoQuant == 1 and RakoQuant[1] != 1
bearFlip = RakoQuant == -1 and RakoQuant[1] != -1

stateCol = RakoQuant == 1 ? bullCol : RakoQuant == -1 ? bearCol : bandCol

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// PLOTS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
uCol = useTrendClr ? stateCol : bullCol
lCol = useTrendClr ? stateCol : bearCol

plot(showGlow ? upper : na, "Upper Glow Outer", color=color.new(uCol, 88), linewidth=glowOuterW, style=plotStyle)
plot(showGlow ? lower : na, "Lower Glow Outer", color=color.new(lCol, 88), linewidth=glowOuterW, style=plotStyle)
plot(showGlow ? upper : na, "Upper Glow Inner", color=color.new(uCol, 72), linewidth=glowInnerW, style=plotStyle)
plot(showGlow ? lower : na, "Lower Glow Inner", color=color.new(lCol, 72), linewidth=glowInnerW, style=plotStyle)

pU = plot(upper, "Upper Band", color=uCol, linewidth=mainWidth, style=plotStyle)
pL = plot(lower, "Lower Band", color=lCol, linewidth=mainWidth, style=plotStyle)

plot(showBasis ? kama : na, "KAMA", color=color.new(bandCol, basisOpacity), linewidth=2, style=plot.style_line)

fill(pU, pL, color = showFill ? color.new(stateCol, fillOpacity) : na)

// Candle paint
barcolor(paintBars ? stateCol : na)
plotcandle(open, high, low, close,
     color       = paintBars ? stateCol : na,
     wickcolor   = paintBars ? stateCol : na,
     bordercolor = paintBars ? stateCol : na,
     force_overlay=true)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// MARKERS 
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bool showM = showSignals and markerStyle != "Off"
bool useSmall  = markerSize == "Small"
bool useNormal = markerSize == "Normal"
bool useLarge  = markerSize == "Large"

// Triangles
plotshape(showM and bullFlip and markerStyle == "Triangles" and useSmall,
     title="Bull Flip (Tri S)", style=shape.triangleup, location=location.belowbar,
     size=size.small, color=bullCol)
plotshape(showM and bullFlip and markerStyle == "Triangles" and useNormal,
     title="Bull Flip (Tri N)", style=shape.triangleup, location=location.belowbar,
     size=size.normal, color=bullCol)
plotshape(showM and bullFlip and markerStyle == "Triangles" and useLarge,
     title="Bull Flip (Tri L)", style=shape.triangleup, location=location.belowbar,
     size=size.large, color=bullCol)

plotshape(showM and bearFlip and markerStyle == "Triangles" and useSmall,
     title="Bear Flip (Tri S)", style=shape.triangledown, location=location.abovebar,
     size=size.small, color=bearCol)
plotshape(showM and bearFlip and markerStyle == "Triangles" and useNormal,
     title="Bear Flip (Tri N)", style=shape.triangledown, location=location.abovebar,
     size=size.normal, color=bearCol)
plotshape(showM and bearFlip and markerStyle == "Triangles" and useLarge,
     title="Bear Flip (Tri L)", style=shape.triangledown, location=location.abovebar,
     size=size.large, color=bearCol)

// Labels
plotshape(showM and bullFlip and markerStyle == "Labels" and useSmall,
     title="Bull Flip (Lbl S)", style=shape.labelup, location=location.belowbar,
     size=size.small, color=bullCol, text="UP", textcolor=color.black)
plotshape(showM and bullFlip and markerStyle == "Labels" and useNormal,
     title="Bull Flip (Lbl N)", style=shape.labelup, location=location.belowbar,
     size=size.normal, color=bullCol, text="UP", textcolor=color.black)
plotshape(showM and bullFlip and markerStyle == "Labels" and useLarge,
     title="Bull Flip (Lbl L)", style=shape.labelup, location=location.belowbar,
     size=size.large, color=bullCol, text="UP", textcolor=color.black)

plotshape(showM and bearFlip and markerStyle == "Labels" and useSmall,
     title="Bear Flip (Lbl S)", style=shape.labeldown, location=location.abovebar,
     size=size.small, color=bearCol, text="DN", textcolor=color.white)
plotshape(showM and bearFlip and markerStyle == "Labels" and useNormal,
     title="Bear Flip (Lbl N)", style=shape.labeldown, location=location.abovebar,
     size=size.normal, color=bearCol, text="DN", textcolor=color.white)
plotshape(showM and bearFlip and markerStyle == "Labels" and useLarge,
     title="Bear Flip (Lbl L)", style=shape.labeldown, location=location.abovebar,
     size=size.large, color=bearCol, text="DN", textcolor=color.white)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ALERTS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
alertcondition(bullFlip, "RQ KAMA SD Bull Flip", "KAMA SD Bands turned UP {{exchange}}:{{ticker}}")
alertcondition(bearFlip, "RQ KAMA SD Bear Flip", "KAMA SD Bear Flip", "KAMA SD Bands turned DOWN {{exchange}}:{{ticker}}")
