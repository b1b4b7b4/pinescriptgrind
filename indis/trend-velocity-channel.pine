import TradingView/ta/12 as ta 

//@version=6
indicator("Trend Velocity Channel [BackQuant]", overlay=true)

// constants
const string calc = "Calculation Settings"
const string lvls = "Level Settings"
const string plt = "Plotting and UI Settings"
const color GREEN = #00ff00
const color RED = #ff0000

// User inputs
float price      = input.source(hlcc4, "Price Source", group=calc)
int   maLen      = input.int(14, "MA Length", group=calc)
int   crushSmth  = input.int(6, "Crush Smoothing", group=calc)
int   atrLen     = input.int(23, "ATR Length", group=calc)
float chanPad    = input.float(0.5, "Channel Padding (ATR)", minval=0.1, maxval=1.5, step=0.1, group=calc, tooltip="Extra space beyond the lagging MA for the outer edge")
bool  showLevels = input.bool(true, "Show Crush Reversal Levels", group=lvls)
int   maxLvls    = input.int(8, "Max Levels", minval=2, maxval=100, group=lvls)
bool  showGlow   = input.bool(true, "Glow on DEMA", group=plt)
bool  paintBars  = input.bool(true, "Color Candles", group=plt)
bool  showFill   = input.bool(true, "Show Channel Fill", group=plt)
color longcol    = input.color(GREEN, "Long Color", inline="col", group=plt)
color shortcol   = input.color(RED, "Short Color", inline="col", group=plt)

// Core calc
dema=ta.dema(price, maLen)
lagMA = ta.ema(price, math.round(maLen * 1.5))  // Slow lagging EMA
atr = ta.atr(atrLen)

// Crush = gap between leading DEMA and lagging EMA
rawCrush = (dema - lagMA) / atr
crush = ta.ema(rawCrush, crushSmth)
crushAbs = math.abs(crush)
crushHigh = ta.highest(crushAbs, 80)
crushNorm = crushHigh > 0 ? math.min(crushAbs / crushHigh, 1.0) : 0.0

int trend = crush > 0 ? 1 : -1
bool flip = trend != trend[1]

// Channel
float inner = dema
float outer = trend == 1 ? lagMA - atr * chanPad : lagMA + atr * chanPad

// Midpoints for 3-layer ribbon fill
float mid1 = inner + (outer - inner) * 0.33
float mid2 = inner + (outer - inner) * 0.66

// coloring
trendcol = trend == 1 ? color.from_gradient(crushNorm, 0.05, 0.7, color.new(longcol, 45), longcol) : color.from_gradient(crushNorm, 0.05, 0.7, color.new(shortcol, 45), shortcol)

// reversal levels
type levels
    float kline
    int   dir
    line  ln
    bool  retested

var levels[] cLevels = array.new<levels>()

if flip and showLevels
    if cLevels.size() >= maxLvls
        levels old = cLevels.shift()
        line.delete(old.ln)

    float lvlkline = trend == 1 ? low : high
    lCol = trend == 1 ? longcol : shortcol
    line ln = line.new(bar_index, lvlkline, bar_index + 60, lvlkline, color=color.new(lCol, 30), width=1, style=line.style_dashed)
    cLevels.push(levels.new(lvlkline, trend, ln, false))

if cLevels.size() > 0
    int i = cLevels.size() - 1
    while i >= 0
        levels lvl = cLevels.get(i)
        bool broken = lvl.dir == 1 ? close < lvl.kline - atr * 2.5 : close > lvl.kline + atr * 2.5
        if broken
            line.delete(lvl.ln)
            cLevels.remove(i)
        else
            line.set_x2(lvl.ln, bar_index + 60)
            bool touch = math.abs(close - lvl.kline) < atr * 0.25 and math.abs(close[2] - lvl.kline) > atr * 0.5
            if touch and not lvl.retested
                lvlcol = lvl.dir == 1 ? longcol : shortcol
                yPos = close > lvl.kline ? low : high
                lStyle = close > lvl.kline ? label.style_label_up : label.style_label_down
                label.new(bar_index, yPos, "x", style=lStyle, color=color(na), textcolor=lvlcol, size=size.small)
                lvl.retested := true
        i -= 1

// Plotting 
glowW = atr * 0.07 * (0.5 + crushNorm)
g3p = plot(showGlow ? dema + glowW * 3 : na, display=display.none)
g2p = plot(showGlow ? dema + glowW * 2 : na, display=display.none)
g1p = plot(showGlow ? dema + glowW     : na, display=display.none)
pDEMA = plot(dema, "DEMA Lead", trendcol, 2)
g1b = plot(showGlow ? dema - glowW     : na, display=display.none)
g2b = plot(showGlow ? dema - glowW * 2 : na, display=display.none)
g3b = plot(showGlow ? dema - glowW * 3 : na, display=display.none)

fill(g3p, g2p, showGlow ? color.new(trendcol, 94) : na)
fill(g2p, g1p, showGlow ? color.new(trendcol, 88) : na)
fill(g1p, pDEMA, showGlow ? color.new(trendcol, 78) : na)
fill(pDEMA, g1b, showGlow ? color.new(trendcol, 78) : na)
fill(g1b, g2b, showGlow ? color.new(trendcol, 88) : na)
fill(g2b, g3b, showGlow ? color.new(trendcol, 94) : na)

pInner = plot(inner, display=display.none)
pMid1  = plot(mid1, display=display.none)
pMid2  = plot(mid2, display=display.none)
pOuter = plot(outer, "Lag MA Outer", color.new(trendcol, 60), 1)

fill(pInner, pMid1, color.new(trendcol, showFill ? 75 : 100))
fill(pMid1, pMid2, color.new(trendcol, showFill ? 83 : 100))
fill(pMid2, pOuter, color.new(trendcol, showFill ? 90 : 100))

float bandBrk = flip ? float(na) : outer
pmB = plot(bandBrk, "Channel Edge", trendcol, 2, plot.style_linebr)
ppHL = plot(hl2, display=display.none, editable=false)
fill(pmB, ppHL, hl2, bandBrk, color(na), color.new(trendcol, 82), editable=false)

plotcandle(open, high, low, close, "Candles", trendcol, trendcol, bordercolor=trendcol, display=paintBars ? display.all : display.none)

if flip and trend == 1
    label.new(bar_index, low, "▲", style=label.style_label_up, color=color(na), textcolor=longcol, size=size.normal)
if flip and trend == -1
    label.new(bar_index, high, "▼", style=label.style_label_down, color=color(na), textcolor=shortcol, size=size.normal)

alertcondition(flip and trend == 1, "Crush Bull", "Lag crush bullish {{ticker}}")
alertcondition(flip and trend == -1, "Crush Bear", "Lag crush bearish {{ticker}}")
alertcondition(crushNorm > 0.85, "Peak Crush", "Peak lag crush — strong acceleration {{ticker}}")
