// Pine Script®
// © RakoQuant

//@version=6
indicator("ADX SuperTrend | RakoQuant", shorttitle="RQ ADX ST", overlay=true, max_labels_count=500)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// INPUTS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
group_core = "Core"
group_mech = "Mechanism"
group_viz  = "Visuals"

src      = input.source(high, "Source", group=group_core)
baseLen  = input.int(12, "Baseline Length (EMA)", minval=1, group=group_core)
atrLen   = input.int(43, "ATR Length", minval=1, group=group_core)

// ADX adaptivity
adxLen    = input.int(16, "ADX Length", minval=1, group=group_mech)
multBase  = input.float(2.5, "Base Multiplier", minval=0.1, step=0.1, group=group_mech)
adxFloor  = input.float(10.0, "ADX Floor", minval=0.0, step=0.5, group=group_mech)
adxCeil   = input.float(35.0, "ADX Ceiling", minval=1.0, step=0.5, group=group_mech)
boostMax  = input.float(1.50, "Max Boost (xMult)", minval=1.0, step=0.05, group=group_mech)
boostPow  = input.float(0.65, "Boost Power", minval=0.1, step=0.05, group=group_mech)

// Optional momentum gate (baseline slope normalized by ATR)
momLen   = input.int(2, "Momentum Lookback", minval=1, group=group_mech)
momGate  = input.float(0.1, "Momentum Gate (ATR units)", minval=0.0, step=0.01, group=group_mech)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// VISUAL OPTIONS (open-source friendly)
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
palette = input.string("Classic", "Palette",
     options=["RakoQuant Neon", "Classic", "Gold / Indigo", "Ocean / Coral", "Mono"],
     group=group_viz)

lineStyleOpt = input.string("Line Break", "Line Style",
     options=["Line Break", "Line", "Step"],
     group=group_viz)

showGlow    = input.bool(true, "Glow Effect", group=group_viz)
glowOuterW  = input.int(10, "Glow Outer Width", minval=1, maxval=20, group=group_viz)
glowInnerW  = input.int(6,  "Glow Inner Width", minval=1, maxval=20, group=group_viz)
mainWidth   = input.int(2,  "Main Width", minval=1, maxval=6, group=group_viz)

showFill    = input.bool(true, "Show Fill", group=group_viz)
fillOpacity = input.int(85, "Fill Opacity", minval=0, maxval=100, group=group_viz)
fillMode    = input.string("To Mid", "Fill Mode", options=["To Mid", "To Price", "Off"], group=group_viz)

paintBars   = input.bool(true, "Paint Candles", group=group_viz)
showSignals = input.bool(true, "Show UP/DN Markers", group=group_viz)
markerStyle = input.string("Labels", "Marker Style", options=["Labels","Triangles","Off"], group=group_viz)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// COLORS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bullCol =
     palette == "Classic"       ? color.lime :
     palette == "Gold / Indigo" ? color.rgb(255, 196, 0) :
     palette == "Ocean / Coral" ? color.rgb(0, 220, 255) :
     palette == "Mono"          ? color.rgb(230, 230, 230) :
                                  #00ffc3

bearCol =
     palette == "Classic"       ? color.red :
     palette == "Gold / Indigo" ? color.rgb(96, 86, 255) :
     palette == "Ocean / Coral" ? color.rgb(255, 105, 120) :
     palette == "Mono"          ? color.rgb(140, 140, 140) :
                                  #ff00d0

midCol = color.new(color.gray, 0)

plotStyle =
     lineStyleOpt == "Line" ? plot.style_line :
     lineStyleOpt == "Step" ? plot.style_stepline :
                              plot.style_linebr

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ENGINE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
baseline = ta.ema(src, baseLen)
atr      = ta.atr(atrLen)

// ADX (Pine-safe way): use DMI function
// NOTE: second parameter is the ADX smoothing. Using same length keeps it clean.
[pdi, mdi, adx] = ta.dmi(adxLen, adxLen)

// Normalize ADX into 0..1 between floor..ceil
float denom = (adxCeil - adxFloor)
float tRaw  = denom != 0.0 ? (adx - adxFloor) / denom : 0.0
float t     = math.max(math.min(tRaw, 1.0), 0.0)

// Convert to multiplier scale
float scaleRaw = 1.0 + (boostMax - 1.0) * math.pow(t, boostPow)
float scale    = math.max(math.min(scaleRaw, boostMax), 1.0)

effMult = multBase * scale

upperband = baseline + effMult * atr
lowerband = baseline - effMult * atr

// Trailing bands (SuperTrend logic)
prevupper = nz(upperband[1])
prevlower = nz(lowerband[1])

upperband := upperband < prevupper or close[1] > prevupper ? upperband : prevupper
lowerband := lowerband > prevlower or close[1] < prevlower ? lowerband : prevlower

// Optional momentum confirmation
mom     = baseline - baseline[momLen]
momNorm = atr != 0.0 ? mom / atr : 0.0

// Trend state (dir < 0 bullish like your convention)
int dir = na
float st = na
prevst = nz(st[1])

if na(baseline[1]) or na(atr[1])
    dir := 1
else if prevst == prevupper
    dir := (close > upperband and momNorm > momGate) ? -1 : 1
else
    dir := (close < lowerband and momNorm < -momGate) ? 1 : -1

st := dir == -1 ? lowerband : upperband

activeCol = dir < 0 ? bullCol : bearCol
stBull = dir < 0 ? st : na
stBear = dir > 0 ? st : na

bullFlip = dir < 0 and dir[1] > 0
bearFlip = dir > 0 and dir[1] < 0

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// PLOTTING + GLOW + FILL
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
plot(showGlow ? stBull : na, "Bull Glow Outer", color=color.new(bullCol, 88), linewidth=glowOuterW, style=plotStyle)
plot(showGlow ? stBear : na, "Bear Glow Outer", color=color.new(bearCol, 88), linewidth=glowOuterW, style=plotStyle)
plot(showGlow ? stBull : na, "Bull Glow Inner", color=color.new(bullCol, 72), linewidth=glowInnerW, style=plotStyle)
plot(showGlow ? stBear : na, "Bear Glow Inner", color=color.new(bearCol, 72), linewidth=glowInnerW, style=plotStyle)

bullPlot = plot(stBull, "Bull Band", color=bullCol, linewidth=mainWidth, style=plotStyle)
bearPlot = plot(stBear, "Bear Band", color=bearCol, linewidth=mainWidth, style=plotStyle)

// Fill refs
midPlot   = plot((open + close) / 2, "Mid", color=na)
pricePlot = plot(close, "Close", color=na)

fill(midPlot, bullPlot,   color = showFill and dir < 0 and fillMode == "To Mid"    ? color.new(bullCol, fillOpacity) : na)
fill(midPlot, bearPlot,   color = showFill and dir > 0 and fillMode == "To Mid"    ? color.new(bearCol, fillOpacity) : na)
fill(pricePlot, bullPlot, color = showFill and dir < 0 and fillMode == "To Price"  ? color.new(bullCol, fillOpacity) : na)
fill(pricePlot, bearPlot, color = showFill and dir > 0 and fillMode == "To Price"  ? color.new(bearCol, fillOpacity) : na)

// Candle paint
barcolor(paintBars ? activeCol : na)
plotcandle(open, high, low, close,
     color       = paintBars ? activeCol : na,
     wickcolor   = paintBars ? activeCol : na,
     bordercolor = paintBars ? activeCol : na,
     force_overlay=true)

// Markers toggle
bool showM = showSignals and markerStyle != "Off"

plotshape(showM and bullFlip and barstate.isconfirmed and markerStyle == "Triangles",
     title="Bull Flip", style=shape.triangleup, location=location.belowbar,
     size=size.tiny, color=bullCol)

plotshape(showM and bearFlip and barstate.isconfirmed and markerStyle == "Triangles",
     title="Bear Flip", style=shape.triangledown, location=location.abovebar,
     size=size.tiny, color=bearCol)

plotshape(showM and bullFlip and barstate.isconfirmed and markerStyle == "Labels",
     title="Bull Flip", style=shape.labelup, location=location.belowbar,
     size=size.tiny, color=bullCol, text="UP", textcolor=color.black)

plotshape(showM and bearFlip and barstate.isconfirmed and markerStyle == "Labels",
     title="Bear Flip", style=shape.labeldown, location=location.abovebar,
     size=size.tiny, color=bearCol, text="DN", textcolor=color.white)

// Alerts
alertcondition(bullFlip, "RQ ADX ST Bull Flip", "ADX SuperTrend turned UP {{exchange}}:{{ticker}}")
alertcondition(bearFlip, "RQ ADX ST Bear Flip", "ADX SuperTrend turned DOWN {{exchange}}:{{ticker}}")
