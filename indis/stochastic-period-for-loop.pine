//@version=6

// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/

// © SeerQuant

indicator(
 title = "Stochastic For Loop [SeerQuant]",
 shorttitle = "𝐒𝐅𝐋 [SeerQuant]",
 overlay = false
 )

// ----------------- ＳＴＡＴＩＣ ＶＡＲＩＡＢＬＥＳ ----------------- //

const string g1 = "Stochastic Sweep"
const string g2 = "Overlay"
const string g3 = "Style Settings"

// ----------------- ＩＮＰＵＴ ＶＡＲＩＡＢＬＥＳ ----------------- //

// ​🇸​​🇹​​🇷​​🇮​​🇳​​🇬​​🇸​
string colScheme  = input.string(defval = "Default", title = "Colour Choice",
                                  options = ["Default", "Modern",
                                      "Cool", "Monochrome"],                          group = g3)

string colcMode   = input.string(defval = "SFL", title = "Candle Color Mode",
                                  options = ["SFL", "Signal Line"],                   group = g3)

//​🇫​​🇱​​🇴​​🇦​​🇹​​🇸​
float source      = input.source(defval = close,    title = "Source",                  group = g1)

//​🇮​​🇳​​🇹​​🇸​
int kSmooth       = input.int   (defval = 1,     title = "%K Smoothing",               group = g1, minval = 1,
                                  tooltip = "SMA smoothing applied to raw %K at each swept period before scoring.")
int sl            = input.int   (defval = 20,    title = "Loop Start",                 group = g1, minval = 1,
                                  tooltip = "Shortest Stochastic period to scan.")
int el            = input.int   (defval = 45,    title = "Loop End",                   group = g1, maxval = 60,
                                  tooltip = "Longest Stochastic period to scan. Max 60.")
float thrUp       = input.float (defval = 20,    title = "Threshold Uptrend",          group = g1,
                                  tooltip = "Score above this = bullish regime.")
float thrDown     = input.float (defval = -3,    title = "Threshold Downtrend",        group = g1,
                                  tooltip = "Score below this = bearish regime.")
float obLevel     = input.float (defval = 80,    title = "OB Level",                   group = g1,
                                  tooltip = "Stochastic above this = overbought at that period.")
float osLevel     = input.float (defval = 20,    title = "OS Level",                   group = g1,
                                  tooltip = "Stochastic below this = oversold at that period.")
int maLen         = input.int   (defval = 21,    title = "Overlay MA Length",           group = g2, minval = 2)

//​🇧​​🇴​​🇴​​🇱​​🇸​
bool colc         = input.bool  (defval = false,  title = "Color Candles?",            group = g3)
bool cust         = input.bool  (defval = false,  title = "Use Custom Colors?",        group = g3)

//​🇨​​🇴​​🇱​​🇴​​🇷​​🇸​
color bullc       = input.color (defval = #00ff00, title = "Bull Colour",             group = g3)
color bearc       = input.color (defval = #ff0000, title = "Bear Colour",             group = g3)
color neutralc    = input.color (defval = #6c6c6c, title = "Neutral Colour",          group = g3)

[bulld, beard] = switch colScheme
    "Default"    =>  [#00ff00, #ff0000]
    "Modern"     =>  [#23d7e4, #e11179]
    "Cool"       =>  [#00ffcc, #4e4f75]
    "Monochrome" =>  [#ffffff, #4e4e4e]

[bull, bear] = switch cust
    false => [bulld, beard]
    true  => [bullc, bearc]

color neutral = cust ? neutralc : #6c6c6c

// ----------------- ＰＲＥ-ＣＯＭＰＵＴＥ ----------------- //

// Pine Script requires ta.* functions to be called at the top level on every bar.
// We pre-compute Stochastic %K for every possible period in the sweep range,
// store them in an array, then the scoring loop reads from it.

var int maxPeriods = 200
var stochArr = array.new_float(maxPeriods, 0.0)

array.set(stochArr, 0, 0.0)

f_k(int len) => ta.sma(ta.stoch(close, high, low, len), kSmooth)

k1  = f_k(1),  k2  = f_k(2),  k3  = f_k(3),  k4  = f_k(4),  k5  = f_k(5)
k6  = f_k(6),  k7  = f_k(7),  k8  = f_k(8),  k9  = f_k(9),  k10 = f_k(10)
k11 = f_k(11), k12 = f_k(12), k13 = f_k(13), k14 = f_k(14), k15 = f_k(15)
k16 = f_k(16), k17 = f_k(17), k18 = f_k(18), k19 = f_k(19), k20 = f_k(20)
k21 = f_k(21), k22 = f_k(22), k23 = f_k(23), k24 = f_k(24), k25 = f_k(25)
k26 = f_k(26), k27 = f_k(27), k28 = f_k(28), k29 = f_k(29), k30 = f_k(30)
k31 = f_k(31), k32 = f_k(32), k33 = f_k(33), k34 = f_k(34), k35 = f_k(35)
k36 = f_k(36), k37 = f_k(37), k38 = f_k(38), k39 = f_k(39), k40 = f_k(40)
k41 = f_k(41), k42 = f_k(42), k43 = f_k(43), k44 = f_k(44), k45 = f_k(45)
k46 = f_k(46), k47 = f_k(47), k48 = f_k(48), k49 = f_k(49), k50 = f_k(50)
k51 = f_k(51), k52 = f_k(52), k53 = f_k(53), k54 = f_k(54), k55 = f_k(55)
k56 = f_k(56), k57 = f_k(57), k58 = f_k(58), k59 = f_k(59), k60 = f_k(60)

// Pack into array
array.set(stochArr,1,k1),   array.set(stochArr,2,k2),   array.set(stochArr,3,k3),   array.set(stochArr,4,k4),   array.set(stochArr,5,k5)
array.set(stochArr,6,k6),   array.set(stochArr,7,k7),   array.set(stochArr,8,k8),   array.set(stochArr,9,k9),   array.set(stochArr,10,k10)
array.set(stochArr,11,k11), array.set(stochArr,12,k12), array.set(stochArr,13,k13), array.set(stochArr,14,k14), array.set(stochArr,15,k15)
array.set(stochArr,16,k16), array.set(stochArr,17,k17), array.set(stochArr,18,k18), array.set(stochArr,19,k19), array.set(stochArr,20,k20)
array.set(stochArr,21,k21), array.set(stochArr,22,k22), array.set(stochArr,23,k23), array.set(stochArr,24,k24), array.set(stochArr,25,k25)
array.set(stochArr,26,k26), array.set(stochArr,27,k27), array.set(stochArr,28,k28), array.set(stochArr,29,k29), array.set(stochArr,30,k30)
array.set(stochArr,31,k31), array.set(stochArr,32,k32), array.set(stochArr,33,k33), array.set(stochArr,34,k34), array.set(stochArr,35,k35)
array.set(stochArr,36,k36), array.set(stochArr,37,k37), array.set(stochArr,38,k38), array.set(stochArr,39,k39), array.set(stochArr,40,k40)
array.set(stochArr,41,k41), array.set(stochArr,42,k42), array.set(stochArr,43,k43), array.set(stochArr,44,k44), array.set(stochArr,45,k45)
array.set(stochArr,46,k46), array.set(stochArr,47,k47), array.set(stochArr,48,k48), array.set(stochArr,49,k49), array.set(stochArr,50,k50)
array.set(stochArr,51,k51), array.set(stochArr,52,k52), array.set(stochArr,53,k53), array.set(stochArr,54,k54), array.set(stochArr,55,k55)
array.set(stochArr,56,k56), array.set(stochArr,57,k57), array.set(stochArr,58,k58), array.set(stochArr,59,k59), array.set(stochArr,60,k60)

// ----------------- ＣＡＬＣＵＬＡＴＩＯＮＳ ----------------- //

// @description: Score by reading from pre-computed arrays
float score = 0.0
float midpoint = (obLevel + osLevel) / 2.0
float halfSpan = (obLevel - osLevel) / 2.0

for i = sl to el by 1
    if i >= 1 and i <= 60
        float k = array.get(stochArr, i)
        float zoneScore = halfSpan != 0 ? (k - midpoint) / halfSpan : 0.0
        zoneScore := math.max(-1.0, math.min(1.0, zoneScore))
        score += zoneScore

// @description: Smoothed signal line
float signalLine = ta.ema(score, 5)

// @description: Signal state
bool goLong  = score > thrUp
bool goShort = score < thrDown

var int signal = 0
if goLong and not goShort
    signal := 1
if goShort
    signal := -1

// @description: State tracking for transition alerts
var int prevTrendState    = 0
var int currentTrendState = 0

if score > thrUp
    currentTrendState := 1
else if score < thrDown
    currentTrendState := -1
else
    currentTrendState := 0

bool bullishTransition = prevTrendState != 1  and currentTrendState == 1
bool bearishTransition = prevTrendState != -1 and currentTrendState == -1

if bullishTransition or bearishTransition
    prevTrendState := currentTrendState

// ----------------- ＰＬＯＴＴＩＮＧ ----------------- //

// @description: Color logic
color hist_color = signal == 1 ? bull : signal == -1 ? bear : neutral

// @description: Zero line
mid = plot(0,       color = color.new(chart.fg_color, 50), style = plot.style_line, linewidth = 1, title = "Zero Line")

// @description: Score line and signal line
p = plot(score,      color = color.new(score > thrUp ? bull : score < thrDown ? bear : neutral, 0), linewidth = 1, title = "SFL Score")
plot(signalLine,     color = color.gray, linewidth = 1, title = "Signal Line")

// @description: Fill between score and zero (RSI-style gradient sweep)
fill(p, mid, color = score > thrUp ? color.new(bull, 90) : (score < thrDown ? color.new(bear, 90) : color.new(neutral, 90)))
fill(p, mid, score, 0, color.new(chart.bg_color, 100), score > thrUp ? bull : (score < thrDown ? bear : neutral))

// @description: Overlay EMA coloured by signal state
float ovMA = ta.ema(close, maLen)
plot(ovMA, color = hist_color, linewidth = 3, force_overlay = true, title = "Signal MA")

// @description: Optional candle colouring
float colorSrc = colcMode == "SFL" ? score : signalLine
color col = colorSrc > thrUp ? bull : colorSrc < thrDown ? bear : neutral
plotcandle(open, high, low, close, color = colc ? col : na, wickcolor = colc ? col : na, bordercolor = colc ? col : na, force_overlay = true)

// ----------------- ＡＬＥＲＴＳ ----------------- //

alertcondition(signal == 1,       title = "SFL Bullish",          message = "SFL Bullish on: {{exchange}}:{{ticker}}")
alertcondition(signal == -1,      title = "SFL Bearish",          message = "SFL Bearish on: {{exchange}}:{{ticker}}")
alertcondition(bullishTransition, title = "SFL Bull Transition",  message = "SFL Bull Transition on: {{exchange}}:{{ticker}}")
alertcondition(bearishTransition, title = "SFL Bear Transition",  message = "SFL Bear Transition on: {{exchange}}:{{ticker}}")

