// Pine Script®
// © RakoQuant

//@version=6
indicator("SWMA Momentum SuperTrend | RakoQuant", shorttitle="RQ SWMA MOM ST", overlay=true)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// MODE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
mode = input.string("Custom", "Mode", options=["Daily / Swing", "Intraday", "Custom"], group="Mode")

// Presets (tweak later)
preset_swmaSmooth_daily = input.int(8, "Daily SWMA Smooth", minval=1, group="Mode Presets")
preset_atrLen_daily     = input.int(15, "Daily ATR Len",     minval=1, group="Mode Presets")
preset_factor_daily     = input.float(3.2, "Daily Factor",   minval=0.1, step=0.1, group="Mode Presets")
preset_momLen_daily     = input.int(11, "Daily Mom Len",     minval=1, group="Mode Presets")

preset_swmaSmooth_intra = input.int(8,  "Intraday SWMA Smooth", minval=1, group="Mode Presets")
preset_atrLen_intra     = input.int(10, "Intraday ATR Len",     minval=1, group="Mode Presets")
preset_factor_intra     = input.float(2.2, "Intraday Factor",   minval=0.1, step=0.1, group="Mode Presets")
preset_momLen_intra     = input.int(7,  "Intraday Mom Len",     minval=1, group="Mode Presets")

// Custom inputs 
swmaSmooth_custom = input.int(10, "SWMA Smoothing Length", minval=1, group="Custom")
atrLen_custom     = input.int(25, "ATR Length",           minval=1, group="Custom")
factor_custom     = input.float(0.2, "Factor",            minval=0.1, step=0.1, group="Custom")
momLen_custom     = input.int(15, "Momentum Length",      minval=1, group="Custom")

// Source
src = input.source(high, "Source", group="Source")

// Visuals
paintBars = input.bool(true, "Paint Candles", group="Visuals")
showFill  = input.bool(true, "Show Trend Fill", group="Visuals")
showTextSignals = input.bool(false, "Show UP / DN Labels", group="Visuals")

// Optional smoothing (helps reduce chop)
useSmooth = input.bool(true, "Use Signal Smoothing", group="Filter")
smoothLen = input.int(3, "Smoothing Length", minval=1, group="Filter")

// Momentum gating strength (0 = off, 1 = strict)
momGate = input.float(0.7, "Momentum Gate (0..1)", minval=0, maxval=1, step=0.05, group="Filter")

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// VISUAL OPTIONS 
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
palette = input.string("Gold / Indigo", "Palette",
     options=["RakoQuant Neon", "Classic", "Gold / Indigo", "Ocean / Coral", "Mono"],
     group="Visuals")

lineStyleOpt = input.string("Line Break", "Line Style",
     options=["Line Break", "Step", "Line"],
     group="Visuals")

showGlow    = input.bool(true, "Glow Effect", group="Visuals")
glowWidth   = input.int(6, "Glow Width", minval=1, maxval=12, group="Visuals")
mainWidth   = input.int(2, "Main Width", minval=1, maxval=6, group="Visuals")
showBase    = input.bool(true, "Show SWMA Baseline", group="Visuals")
baseOpacity = input.int(70, "Baseline Opacity", minval=0, maxval=100, group="Visuals")

showSignals = input.bool(true, "Show Flip Markers", group="Visuals")
fillMode    = input.string("To Mid", "Fill Mode", options=["To Mid", "To Price", "Off"], group="Visuals")
fillOpacity = input.int(85, "Fill Opacity", minval=0, maxval=100, group="Visuals")

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// RESOLVE ACTIVE SETTINGS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
swmaSmooth = mode == "Custom" ? swmaSmooth_custom : mode == "Intraday" ? preset_swmaSmooth_intra : preset_swmaSmooth_daily
atrLen     = mode == "Custom" ? atrLen_custom     : mode == "Intraday" ? preset_atrLen_intra     : preset_atrLen_daily
factor     = mode == "Custom" ? factor_custom     : mode == "Intraday" ? preset_factor_intra     : preset_factor_daily
momLen     = mode == "Custom" ? momLen_custom     : mode == "Intraday" ? preset_momLen_intra     : preset_momLen_daily

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ENGINE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
swma_raw = ta.swma(src)
baseline = ta.ema(swma_raw, swmaSmooth)

atr = ta.atr(atrLen)
mom = baseline - baseline[momLen]

// Optional smoothing for baseline + momentum + atr (esp intraday)
baseline_s = (useSmooth and mode == "Intraday") ? ta.ema(baseline, smoothLen) : baseline
atr_s      = (useSmooth and mode == "Intraday") ? ta.ema(atr, smoothLen)      : atr
mom_s      = (useSmooth and mode == "Intraday") ? ta.ema(mom, smoothLen)      : mom

upperband = baseline_s + factor * atr_s
lowerband = baseline_s - factor * atr_s

prevupper = nz(upperband[1])
prevlower = nz(lowerband[1])

upperband := upperband < prevupper or close[1] > prevupper ? upperband : prevupper
lowerband := lowerband > prevlower or close[1] < prevlower ? lowerband : prevlower

momNorm = atr_s != 0.0 ? mom_s / atr_s : 0.0
gateUp   = (1.0 - momGate) * 0.0 + momGate * 0.10
gateDown = -(1.0 - momGate) * 0.0 - momGate * 0.10

int dir = na   // dir < 0 bullish, dir > 0 bearish
float st = na

float prevSt    = nz(st[1])
float prevUpper = nz(upperband[1])

if na(baseline_s[1]) or na(atr_s[1])
    dir := 1
else
    bool wasBear  = prevSt == prevUpper
    bool flipBull = close > upperband and momNorm > gateUp
    bool flipBear = close < lowerband and momNorm < gateDown
    dir := wasBear ? (flipBull ? -1 : 1) : (flipBear ? 1 : -1)

st := dir == -1 ? lowerband : upperband

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// COLORS (Palette Options)
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bullCol =
     palette == "Classic"       ? color.lime :
     palette == "Gold / Indigo" ? color.rgb(255, 196, 0) :
     palette == "Ocean / Coral" ? color.rgb(0, 220, 255) :
     palette == "Mono"          ? color.rgb(230, 230, 230) :
                                  #00ffc3   // RQ Neon Aqua

bearCol =
     palette == "Classic"       ? color.red :
     palette == "Gold / Indigo" ? color.rgb(96, 86, 255) :
     palette == "Ocean / Coral" ? color.rgb(255, 105, 120) :
     palette == "Mono"          ? color.rgb(140, 140, 140) :
                                  #ff00d0   // RQ Neon Magenta

activeCol = dir < 0 ? bullCol : bearCol

// Plot style mapping
plotStyle = lineStyleOpt == "Step"     ? plot.style_stepline :  lineStyleOpt == "Line"     ? plot.style_line :   plot.style_linebr

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TRUE SUPERTREND PLOTTING 
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
stBull = dir < 0 ? st : na
stBear = dir > 0 ? st : na

// Glow layer 
plot(showGlow ? stBull : na, "Bull Glow", color=color.new(bullCol, 70), linewidth=glowWidth, style=plotStyle)
plot(showGlow ? stBear : na, "Bear Glow", color=color.new(bearCol, 70), linewidth=glowWidth, style=plotStyle)

// Main layer 
bullPlot = plot(stBull, "Bull Band", color=bullCol, linewidth=mainWidth, style=plotStyle)
bearPlot = plot(stBear, "Bear Band", color=bearCol, linewidth=mainWidth, style=plotStyle)

// Baseline 
plot(showBase ? baseline_s : na, "SWMA Baseline", color=color.new(color.gray, baseOpacity), linewidth=1)

// Fill reference
midPlot   = plot((open + close) / 2, "Mid", color=na)
pricePlot = plot(close, "Close", color=na)

// Fill 
fill(midPlot, bullPlot, color = showFill and dir < 0 and fillMode == "To Mid"   ? color.new(bullCol, fillOpacity) : na)
fill(midPlot, bearPlot, color = showFill and dir > 0 and fillMode == "To Mid"   ? color.new(bearCol, fillOpacity) : na)

fill(pricePlot, bullPlot, color = showFill and dir < 0 and fillMode == "To Price" ? color.new(bullCol, fillOpacity) : na)
fill(pricePlot, bearPlot, color = showFill and dir > 0 and fillMode == "To Price" ? color.new(bearCol, fillOpacity) : na)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// CANDLE PAINT
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
barcolor(paintBars ? activeCol : na)

plotcandle(open, high, low, close,
     color       = paintBars ? activeCol : na,
     wickcolor   = paintBars ? activeCol : na,
     bordercolor = paintBars ? activeCol : na,
     force_overlay=true)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SIGNALS + ALERTS 
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bullFlip = dir < 0 and dir[1] > 0
bearFlip = dir > 0 and dir[1] < 0

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SIGNAL MARKERS 
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bullSig = showSignals and bullFlip and barstate.isconfirmed
bearSig = showSignals and bearFlip and barstate.isconfirmed


plotshape(bullSig and showTextSignals, title="Bull Label",
     style=shape.labelup, location=location.belowbar, size=size.small,
     color=bullCol, text="UP", textcolor=color.black)

plotshape(bearSig and showTextSignals, title="Bear Label",
     style=shape.labeldown, location=location.abovebar, size=size.small,
     color=bearCol, text="DN", textcolor=color.white)

alertcondition(bullSig, "RakoQuant Bull Flip", "SWMA Momentum SuperTrend turned UP {{exchange}}:{{ticker}}")
alertcondition(bearSig, "RakoQuant Bear Flip", "SWMA Momentum SuperTrend turned DOWN {{exchange}}:{{ticker}}")
